rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /items/{itemId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (
          !exists(/databases/(default)/documents/items/$(itemId))
          || get(/databases/(default)/documents/items/$(itemId)).data.ownerId == request.auth.uid
        );
    }
  }
}
